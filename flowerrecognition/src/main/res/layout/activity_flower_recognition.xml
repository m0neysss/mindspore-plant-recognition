<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FA"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/flower_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:navigationIcon="@drawable/ic_flower_back"
        android:titleTextColor="#202124" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/flower_model_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/flower_model_loading"
                android:textColor="#3C4043"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/flower_scope_notice"
                android:textColor="#5F6368"
                android:textSize="13sp" />

            <Button
                android:id="@+id/flower_retry_model"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="@string/flower_retry_model"
                android:textAllCaps="false"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/flower_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:indeterminate="true" />

            <ImageView
                android:id="@+id/flower_preview"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_marginTop="16dp"
                android:background="#E8EAED"
                android:contentDescription="@string/flower_preview_description"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/flower_gallery"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="@string/flower_choose_gallery"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/flower_camera"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="@string/flower_take_photo"
                    android:textAllCaps="false" />
            </LinearLayout>

            <Button
                android:id="@+id/flower_recognize"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="@string/flower_start_recognition"
                android:textAllCaps="false" />

            <TextView
                android:id="@+id/flower_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#FCE8E6"
                android:padding="12dp"
                android:textColor="#B3261E"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/flower_top_three"
                android:textColor="#202124"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/flower_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/flower_result_placeholder"
                android:textColor="#3C4043"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/flower_timing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="20dp"
                android:textColor="#5F6368"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
